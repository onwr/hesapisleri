generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  STAFF
  POS_STAFF
  SUPER_ADMIN
}

enum CompanyInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
  REJECTED
}

enum Status {
  ACTIVE
  PASSIVE
  SUSPENDED
}

enum CompanyUserStatus {
  ACTIVE
  INVITED
  PASSIVE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderSourceChannel {
  MANUAL
  POS
  WEBSITE
  TRENDYOL
  HEPSIBURADA
  N11
  AMAZON
  CICEKSEPETI
  ETSY
  OTHER
}

enum OrderStatus {
  WAITING
  APPROVED
  SHIPPING
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  CANCELLED
}

enum MarketplaceChannel {
  TRENDYOL
  HEPSIBURADA
}

enum MarketplaceIntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
  DISABLED
}

enum MarketplaceSyncRunType {
  MANUAL
  AUTO
  TEST
}

enum MarketplaceSyncRunStatus {
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  RUNNING
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
  FAILED
}

enum ExpenseStatus {
  APPROVED
  PENDING
  CANCELLED
}

enum ExpensePaymentStatus {
  PAID
  UNPAID
}

enum ExpenseCategoryStatus {
  ACTIVE
  PASSIVE
}

enum InvoiceType {
  NORMAL
  E_INVOICE
  E_ARCHIVE
}

enum InvoiceStatus {
  DRAFT
  SENT
  APPROVED
  CANCELLED
  ERROR
}

enum StockMovementType {
  IN
  OUT
  SALE
  RETURN
  ADJUSTMENT
  COUNT
  TRANSFER_IN
  TRANSFER_OUT
}

enum WarehouseStatus {
  ACTIVE
  PASSIVE
}

enum WarehouseTransferStatus {
  COMPLETED
  CANCELLED
}

enum AccountType {
  STATIC // Örnek olarak bırakıldı, CASH ve BANK tiplerini kapsar
  CASH
  BANK
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  COLLECTION
  PAYMENT
}

enum MembershipPaymentStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
}

enum MembershipStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationCategory {
  SALES
  INVOICES
  STOCK
  FINANCE
  SYSTEM
  TEAM
  MARKETPLACE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationChannel {
  IN_APP
}

enum CalendarEventType {
  APPOINTMENT
  PAYMENT
  REMINDER
}

enum CalendarEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CalendarEventSource {
  MANUAL
  SYSTEM
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(OWNER)
  status       Status   @default(ACTIVE)

  companyUsers  CompanyUser[]
  sentInvites   CompanyInvite[] @relation("SentInvites")
  sales        Sale[]
  expenses     Expense[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  warehouseTransfers WarehouseTransfer[]
  calendarEvents CalendarEvent[]
  directoryContacts DirectoryContact[] @relation("DirectoryContactCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id           String @id @default(cuid())
  name         String
  taxNo        String?
  taxOffice    String?
  phone        String?
  email        String?
  address      String?
  logoUrl      String?
  status       Status @default(ACTIVE)

  users              CompanyUser[]
  customers          Customer[]
  customerGroups     CustomerGroup[]
  products           Product[]
  categories         ProductCategory[]
  sales              Sale[]
  invoices           Invoice[]
  expenses           Expense[]
  expenseCategories  ExpenseCategory[]
  accounts           Account[]
  stockMovements     StockMovement[]
  membershipPayments MembershipPayment[]
  notifications      Notification[]
  activityLogs       ActivityLog[]
  settings           CompanySettings?
  invites            CompanyInvite[]
  warehouses         Warehouse[]
  warehouseStocks    WarehouseStock[]
  warehouseTransfers WarehouseTransfer[]
  marketplaceIntegrations MarketplaceIntegration[]
  marketplaceSyncRuns MarketplaceSyncRun[]
  productChannelMappings ProductChannelMapping[]
  calendarEvents         CalendarEvent[]
  employees              Employee[]
  employeeSalaries       EmployeeSalary[]
  employeePayments       EmployeePayment[]
  employeeLeaves         EmployeeLeave[]
  employeePerformanceRecords EmployeePerformanceRecord[]
  employeePerformanceTargets EmployeePerformanceTarget[]
  payrollRuns            PayrollRun[]
  payrollRunItems        PayrollRunItem[]
  employeeDepartments    EmployeeDepartment[]
  directoryContacts      DirectoryContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DirectoryContactType {
  PERSON
  COMPANY
  CUSTOMER
  EMPLOYEE
  SUPPLIER
  OTHER
}

enum DirectorySourceType {
  MANUAL
  CUSTOMER
  EMPLOYEE
  SUPPLIER
}

model DirectoryContact {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type       DirectoryContactType @default(PERSON)
  sourceType DirectorySourceType? @default(MANUAL)
  sourceId   String?

  name         String
  companyName  String?
  title        String?
  department   String?
  phone        String?
  mobilePhone  String?
  email        String?
  website      String?
  address      String?
  city         String?
  district     String?
  taxNumber    String?
  notes        String?
  tags         String[] @default([])
  isFavorite   Boolean  @default(false)
  isActive     Boolean  @default(true)

  createdByUserId String?
  createdByUser   User? @relation("DirectoryContactCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sourceType, sourceId])
  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, isFavorite])
  @@index([companyId, isActive])
}

model CompanyInvite {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email           String
  role            UserRole
  token           String @unique
  status          CompanyInviteStatus @default(PENDING)
  invitedByUserId String
  invitedBy       User @relation("SentInvites", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, email, status])
  @@index([companyId])
}

model CompanySettings {
  id        String @id @default(cuid())

  companyId String @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  currency       String @default("TRY")
  defaultVatRate Int    @default(20)

  defaultInvoiceType  InvoiceType @default(E_ARCHIVE)
  invoiceNumberPrefix String      @default("FTR")
  defaultDueDays      Int         @default(30)
  invoiceNoteTemplate String?

  defaultCollectionAccountId String?
  defaultExpenseAccountId    String?
  autoCreateCashAccount      Boolean @default(true)
  hideInactiveAccounts       Boolean @default(true)

  notifyLowStock        Boolean @default(true)
  notifyDueInvoices     Boolean @default(true)
  notifyLateCollections Boolean @default(true)
  notifyDailySummary    Boolean @default(false)
  notifyEmployeePayments Boolean @default(true)

  membershipStatus MembershipStatus @default(ACTIVE)
  lastPaymentDate  DateTime?
  nextPaymentDate  DateTime?
  monthlyFee       Decimal          @default(1499)
  membershipNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyUser {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      UserRole @default(STAFF)
  status    CompanyUserStatus @default(ACTIVE)
  isOwner   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee?

  @@unique([companyId, userId])
}

model Customer {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  taxNo     String?
  address   String?
  group     String?
  balance   Decimal @default(0)
  status    Status @default(ACTIVE)

  sales     Sale[]
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model CustomerGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  color     String?  @default("blue")
  note      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

enum ProductUnitType {
  PIECE
  KG
  METER
  LITER
  PACK
}

model ProductCategory {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  color     String?
  note      String?
  status    Status @default(ACTIVE)
  sortOrder Int    @default(100)

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  name        String
  sku         String?
  barcode     String?
  description String?
  imageUrl    String?
  stock       Int      @default(0)
  minStock    Int      @default(10)
  unitType    ProductUnitType @default(PIECE)
  warehouseLocation String?
  buyPrice    Decimal @default(0)
  sellPrice   Decimal @default(0)
  vatRate     Int      @default(20)
  status      Status   @default(ACTIVE)

  saleItems          SaleItem[]
  stockMovements     StockMovement[]
  warehouseStocks    WarehouseStock[]
  warehouseTransfers WarehouseTransfer[]
  channelMappings    ProductChannelMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
}

model Warehouse {
  id        String          @id @default(cuid())
  companyId String
  name      String
  code      String?
  address   String?
  note      String?
  isDefault Boolean         @default(false)
  status    WarehouseStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks        WarehouseStock[]
  fromTransfers WarehouseTransfer[] @relation("WarehouseTransferFrom")
  toTransfers   WarehouseTransfer[] @relation("WarehouseTransferTo")
  stockMovements StockMovement[]
  sales          Sale[]
  saleItems      SaleItem[]
  marketplaceIntegrations MarketplaceIntegration[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WarehouseStock {
  id          String   @id @default(cuid())
  companyId   String
  warehouseId String
  productId   String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([companyId])
  @@index([productId])
}

model WarehouseTransfer {
  id              String                  @id @default(cuid())
  companyId       String
  transferNo      String
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  quantity        Int
  note            String?
  status          WarehouseTransferStatus @default(COMPLETED)
  createdByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse       @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse       @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  createdBy     User?           @relation(fields: [createdByUserId], references: [id])
  stockMovements StockMovement[]

  @@unique([companyId, transferNo])
  @@index([companyId])
  @@index([productId])
}

model Sale {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId    String?
  user      User? @relation(fields: [userId], references: [id])

  saleNo    String @unique
  subtotal  Decimal @default(0)
  vatTotal  Decimal @default(0)
  discount  Decimal @default(0)
  total     Decimal @default(0)

  status        SaleStatus    @default(COMPLETED)
  paymentStatus PaymentStatus @default(UNPAID)
  paidAmount    Decimal       @default(0)
  note          String?

  sourceChannel   OrderSourceChannel @default(MANUAL)
  externalOrderId String?
  orderStatus     OrderStatus        @default(WAITING)
  shippingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  orderNote       String?

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  items     SaleItem[]
  invoice   Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([warehouseId])
  @@index([companyId, orderStatus])
  @@index([companyId, sourceChannel])
  @@index([companyId, createdAt])
  @@unique([companyId, sourceChannel, externalOrderId])
}

model SaleItem {
  id        String @id @default(cuid())

  saleId    String
  sale      Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  name      String
  quantity  Int
  unitPrice Decimal
  vatRate   Int @default(20)
  total     Decimal

  createdAt DateTime @default(now())
}

model MarketplaceIntegration {
  id                    String                       @id @default(cuid())
  companyId             String
  channel               MarketplaceChannel
  status                MarketplaceIntegrationStatus @default(DISCONNECTED)
  credentialsEncrypted  String?
  supplierId            String?
  merchantId            String?
  syncEnabled           Boolean                      @default(false)
  autoSyncIntervalMinutes Int                        @default(15)
  defaultWarehouseId    String?
  lastSyncAt            DateTime?
  lastSyncCursor        String?
  lastSyncStatus        String?
  lastError             String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  company               Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultWarehouse      Warehouse?                   @relation(fields: [defaultWarehouseId], references: [id])
  syncRuns              MarketplaceSyncRun[]

  @@unique([companyId, channel])
  @@index([companyId])
}

model MarketplaceSyncRun {
  id            String                 @id @default(cuid())
  companyId     String
  integrationId String
  channel       MarketplaceChannel
  type          MarketplaceSyncRunType
  status        MarketplaceSyncRunStatus
  fetchedCount  Int                    @default(0)
  createdCount  Int                    @default(0)
  updatedCount  Int                    @default(0)
  skippedCount  Int                    @default(0)
  errors        Json?
  startedAt     DateTime               @default(now())
  finishedAt    DateTime?
  createdAt     DateTime               @default(now())

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration   MarketplaceIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([integrationId])
  @@index([channel])
}

model ProductChannelMapping {
  id                String             @id @default(cuid())
  companyId         String
  productId         String
  channel           MarketplaceChannel
  merchantSku       String
  barcode           String?
  externalProductId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel, merchantSku])
  @@index([companyId])
  @@index([productId])
}

model Invoice {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  saleId    String? @unique
  sale      Sale? @relation(fields: [saleId], references: [id])

  invoiceNo String @unique
  type      InvoiceType @default(NORMAL)
  status    InvoiceStatus @default(DRAFT)
  total     Decimal @default(0)

  paymentStatus PaymentStatus @default(UNPAID)
  paidAmount    Decimal       @default(0)

  gibStatus   String?
  gibMessage  String?
  pdfUrl      String?
  xmlUrl      String?

  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions AccountTransaction[]

  @@index([companyId])
}

model ExpenseCategory {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  color     String? @default("blue")
  note      String?
  sortOrder Int     @default(100)
  status    ExpenseCategoryStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Expense {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String?
  user      User? @relation(fields: [userId], references: [id])

  title     String
  category  String?
  supplier  String?
  amount    Decimal
  status    ExpenseStatus @default(APPROVED)
  paymentStatus ExpensePaymentStatus @default(UNPAID)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountTransaction AccountTransaction?
  employeePayments   EmployeePayment[] @relation("EmployeePaymentExpense")
  date      DateTime @default(now())
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([accountId])
}

model Account {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type      AccountType
  name      String
  bankName  String?
  iban      String?
  balance   Decimal @default(0)
  currency  String  @default("TRY")
  status    Status  @default(ACTIVE)

  transactions AccountTransaction[]
  expenses     Expense[]
  employeePayments EmployeePayment[] @relation("EmployeePaymentAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AccountTransaction {
  id        String @id @default(cuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type      TransactionType
  title     String
  amount    Decimal
  date      DateTime @default(now())
  note      String?

  expenseId String? @unique
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  employeePayments EmployeePayment[] @relation("EmployeePaymentTransaction")

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model StockMovement {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  transferId String?
  transfer   WarehouseTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  type         StockMovementType
  quantity     Int
  note         String?
  movementDate DateTime          @default(now())

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([warehouseId])
  @@index([transferId])
}

model MembershipPayment {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal
  status      MembershipPaymentStatus @default(PENDING)

  provider    String?
  paymentRef  String?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Notification {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(SYSTEM)
  module    String?
  entityType String?
  entityId  String?
  actionUrl String?
  metadata  Json?
  priority  NotificationPriority @default(NORMAL)
  channel   NotificationChannel  @default(IN_APP)
  dedupeKey String?

  title     String
  message   String
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, readAt])
  @@index([companyId, category])
  @@index([companyId, priority])
  @@index([companyId, dedupeKey])
  @@index([userId, readAt])
}

model CalendarEvent {
  id          String              @id @default(cuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        CalendarEventType
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean             @default(false)
  amount      Decimal?
  currency    String?
  color       String?
  status      CalendarEventStatus @default(SCHEDULED)
  source      CalendarEventSource @default(MANUAL)
  relatedType String?
  relatedId   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([companyId, startAt])
  @@index([companyId, type])
  @@index([companyId, status])
  @@index([companyId, source])
}

model ActivityLog {
  id        String @id @default(cuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  action    String
  module    String
  message   String?
  ip        String?

  createdAt DateTime @default(now())
}

enum EmployeeStatus {
  ACTIVE
  PASSIVE
  ON_LEAVE
  TERMINATED
}

enum EmployeeEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
  SEASONAL
}

enum EmployeeSalaryPeriod {
  MONTHLY
  WEEKLY
  DAILY
  HOURLY
}

enum EmployeePaymentType {
  SALARY
  ADVANCE
  BONUS
  DEDUCTION
  EXPENSE_REIMBURSEMENT
  OTHER
}

enum EmployeePaymentDirection {
  PAYABLE
  PAID
  DEDUCTED
}

enum EmployeePaymentStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
}

enum EmployeeLeaveType {
  ANNUAL
  SICK
  UNPAID
  EXCUSE
  REMOTE
  OTHER
}

enum EmployeeLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model EmployeeDepartment {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String?

  managerEmployeeId String?
  managerEmployee   Employee? @relation("ManagedDepartments", fields: [managerEmployeeId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  employees Employee[] @relation("EmployeeDepartmentMembership")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Employee {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  companyUserId String? @unique
  companyUser   CompanyUser? @relation(fields: [companyUserId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String
  email     String?
  phone     String?
  avatarUrl String?
  nationalId String?

  jobTitle   String?
  department String?
  departmentId String?
  departmentRef EmployeeDepartment? @relation("EmployeeDepartmentMembership", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments EmployeeDepartment[] @relation("ManagedDepartments")

  employmentType EmployeeEmploymentType @default(FULL_TIME)
  status         EmployeeStatus         @default(ACTIVE)

  startDate DateTime?
  endDate   DateTime?
  birthDate DateTime?
  address   String?

  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?

  salaryRecords       EmployeeSalary[]
  payments            EmployeePayment[]
  leaveRequests       EmployeeLeave[]
  performanceRecords  EmployeePerformanceRecord[]
  performanceTargets  EmployeePerformanceTarget[]
  payrollRunItems     PayrollRunItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, department])
  @@index([companyId, departmentId])
  @@index([companyId, email])
}

model EmployeeSalary {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  amount   Decimal              @db.Decimal(18, 2)
  currency String               @default("TRY")
  period   EmployeeSalaryPeriod @default(MONTHLY)

  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  notes         String?

  payrollRunItems PayrollRunItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([employeeId, isActive])
}

model EmployeePayment {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type      EmployeePaymentType
  direction EmployeePaymentDirection @default(PAYABLE)
  amount    Decimal                  @db.Decimal(18, 2)
  currency  String                   @default("TRY")

  dueDate DateTime?
  paidAt  DateTime?

  status EmployeePaymentStatus @default(PENDING)

  description            String?
  relatedExpenseId       String?
  relatedExpense         Expense? @relation("EmployeePaymentExpense", fields: [relatedExpenseId], references: [id], onDelete: SetNull)
  relatedAccountId       String?
  relatedAccount         Account? @relation("EmployeePaymentAccount", fields: [relatedAccountId], references: [id], onDelete: SetNull)
  relatedTransactionId   String?
  relatedTransaction     AccountTransaction? @relation("EmployeePaymentTransaction", fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  payrollRunItem         PayrollRunItem?
  createdByUserId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@index([relatedExpenseId])
  @@index([relatedAccountId])
  @@index([relatedTransactionId])
}

model EmployeeLeave {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type      EmployeeLeaveType
  startAt   DateTime
  endAt     DateTime
  totalDays Decimal? @db.Decimal(8, 2)

  status EmployeeLeaveStatus @default(PENDING)

  reason           String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdByUserId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@index([companyId, startAt])
}

model EmployeePerformanceRecord {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  salesCount       Int     @default(0)
  salesTotal       Decimal @default(0) @db.Decimal(18, 2)
  posSalesCount    Int     @default(0)
  manualSalesCount Int     @default(0)
  invoiceCount     Int     @default(0)
  expenseCount     Int     @default(0)
  taskScore        Decimal? @db.Decimal(8, 2)
  note             String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([employeeId, periodStart])
  @@unique([employeeId, periodStart, periodEnd])
}

model EmployeePerformanceTarget {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  department String?

  periodStart DateTime
  periodEnd   DateTime

  salesCountTarget        Int?
  revenueTarget           Decimal? @db.Decimal(18, 2)
  collectionTarget        Decimal? @db.Decimal(18, 2)
  maxLeaveDays            Int?
  payrollEfficiencyTarget Decimal? @db.Decimal(8, 2)
  scoreTarget             Decimal? @db.Decimal(8, 2)
  notes                   String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, periodStart, periodEnd])
  @@index([companyId, employeeId])
  @@index([companyId, department])
}

enum PayrollRunStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum PayrollRunItemStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

model PayrollRun {
  id        String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String
  periodStart DateTime
  periodEnd   DateTime
  payDate     DateTime?
  status      PayrollRunStatus @default(DRAFT)
  currency    String           @default("TRY")

  grossTotal     Decimal @default(0) @db.Decimal(18, 2)
  deductionTotal Decimal @default(0) @db.Decimal(18, 2)
  bonusTotal     Decimal @default(0) @db.Decimal(18, 2)
  netTotal       Decimal @default(0) @db.Decimal(18, 2)

  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  paidAt           DateTime?
  notes            String?

  items PayrollRunItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, periodStart, periodEnd])
}

model PayrollRunItem {
  id           String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  salaryId String?
  salary   EmployeeSalary? @relation(fields: [salaryId], references: [id], onDelete: SetNull)

  baseSalary       Decimal @db.Decimal(18, 2)
  bonusAmount      Decimal @default(0) @db.Decimal(18, 2)
  deductionAmount  Decimal @default(0) @db.Decimal(18, 2)
  advanceDeduction Decimal @default(0) @db.Decimal(18, 2)
  netPayable       Decimal @db.Decimal(18, 2)
  currency         String  @default("TRY")
  status           PayrollRunItemStatus @default(DRAFT)

  employeePaymentId String? @unique
  employeePayment   EmployeePayment? @relation(fields: [employeePaymentId], references: [id], onDelete: SetNull)
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([payrollRunId])
  @@index([companyId, employeeId])
}