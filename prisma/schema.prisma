  name                String
  code                String         @unique
  slug                String         @unique
  shortDescription    String?
  description         String?
  badgeText           String?
  planStatus          PlanStatus     @default(ACTIVE)
  visibility          PlanVisibility @default(PUBLIC)
  isFeatured          Boolean        @default(false)
  sortOrder           Int            @default(100)
  trialEnabled        Boolean        @default(true)
  trialDays           Int            @default(14)
  autoRenewAllowed    Boolean        @default(true)
  upgradeAllowed      Boolean        @default(true)
  downgradeAllowed    Boolean        @default(true)
  cancellationAllowed Boolean        @default(true)
  gracePeriodDays     Int            @default(7)
  defaultCurrency     String         @default("TRY")
  vatRate             Int            @default(20)
  vatIncluded         Boolean        @default(false)
  monthlyPrice        Decimal
  quarterlyPrice      Decimal
  semiAnnualPrice     Decimal
  yearlyPrice         Decimal
  currency            String         @default("TRY")
  isActive            Boolean        @default(true)
  features            String[]
  publishedAt         DateTime?
  archivedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

