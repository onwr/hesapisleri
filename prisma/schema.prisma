  id               String                     @id @default(cuid())
  partnerId        String
  partner          PartnerProfile             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  amount           Decimal                    @db.Decimal(18, 2)
  currency         String                     @default("TRY")
  status           PartnerPayoutStatus        @default(DRAFT)
  paymentMethod    PartnerPayoutPaymentMethod @default(MANUAL)
  paymentReference String?
  paidAt           DateTime?
  paidByUserId     String?
  paidByUser       User?                      @relation("PartnerPayoutsPaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)
  note             String?
  createdByUserId  String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  earnings   PartnerEarning[]
  adminNotes AdminPartnerPayoutNote[]

  @@unique([partnerId, paymentReference])
  @@index([partnerId])
  @@index([status])
  @@index([paidByUserId])
}

model PartnerSettings {
  id                     String   @id @default("default")
  defaultCommissionRate  Decimal  @default(10) @db.Decimal(5, 2)
  cookieDurationDays     Int      @default(30)
  minimumPayoutAmount    Decimal  @default(500) @db.Decimal(18, 2)
  autoApproveConversions Boolean  @default(false)
  commissionOnRenewals   Boolean  @default(true)
  isApplicationOpen      Boolean  @default(true)
  termsText              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model CompanyAISettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  enabled                   Boolean  @default(true)
  provider                  String   @default("openai")
  model                     String?
  defaultLanguage           String   @default("tr")
  maxResponseTokens         Int      @default(800)
  monthlyCostWarningUsd     Decimal? @db.Decimal(10, 4)
  readOnlyMode              Boolean  @default(true)
  requireUserApproval       Boolean  @default(true)
  autoDisableOnCostExceeded Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIConversation {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String?
  provider String?
  model    String?

  messages       AIMessage[]
  usageLogs      AIUsageLog[]
  toolExecutions AIToolExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId])
  @@index([userId, updatedAt])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role              String
  content           String
  structuredContent Json?
  sourceModules     String[] @default([])

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model AIUsageLog {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Decimal? @db.Decimal(10, 6)
  durationMs       Int      @default(0)
  toolNames        String[] @default([])
  success          Boolean  @default(true)
  errorCode        String?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model AIToolExecution {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  toolName   String
  inputHash  String?
  success    Boolean @default(true)
  durationMs Int     @default(0)
  errorCode  String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model AIInsightCache {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  cacheKey  String
  content   Json
  provider  String?
  model     String?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cacheKey])
  @@index([expiresAt])
}

model MobileSession {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  companyId      String?
  sessionVersion Int       @default(1)
  expiresAt      DateTime
  revokedAt      DateTime?
  deviceInfo     String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum InvoiceCollectionIdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model InvoiceCollectionIdempotency {
  id                   String                             @id @default(cuid())
  companyId            String
  company              Company                            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  idempotencyKey       String
  payloadHash          String
  status               InvoiceCollectionIdempotencyStatus @default(PROCESSING)
  invoiceId            String?
  accountTransactionId String?
  userId               String?
  result               Json?
  createdAt            DateTime                           @default(now())
  completedAt          DateTime?

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status])
}
