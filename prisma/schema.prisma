model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(OWNER)
  status   Status   @default(ACTIVE)

  // Session invalidation: JWT payload'daki sv bu değerle karşılaştırılır.
  sessionVersion Int @default(1)

  // Login tracking
  lastLoginAt         DateTime?
  loginTrackingStatus LoginTrackingStatus @default(UNKNOWN_LEGACY)

  // Admin suspend metadata
  suspendedAt        DateTime?
  suspendedReason    String?
  suspendedUntil     DateTime?
  suspendedByAdminId String?
  suspendedByAdmin   User?     @relation("SuspendedByAdmin", fields: [suspendedByAdminId], references: [id], onDelete: SetNull)
  suspendedUsers     User[]    @relation("SuspendedByAdmin")

  // Email verification
  emailVerificationStatus EmailVerificationStatus @default(NOT_TRACKED)

  consents                           UserConsent[]
  companyUsers                       CompanyUser[]
  sentInvites                        CompanyInvite[]          @relation("SentInvites")
  sales                              Sale[]                   @relation("SaleCreatedBy")
  cancelledSales                     Sale[]                   @relation("SaleCancelledBy")
  expenses                           Expense[]
  notifications                      Notification[]
  activityLogs                       ActivityLog[]
  warehouseTransfers                 WarehouseTransfer[]
  calendarEvents                     CalendarEvent[]
  directoryContacts                  DirectoryContact[]       @relation("DirectoryContactCreator")
  createdSuppliers                   Supplier[]               @relation("SupplierCreator")
  createdSupplierLedgerEntries       SupplierLedgerEntry[]    @relation("SupplierLedgerCreator")
  aiConversations                    AIConversation[]
  aiUsageLogs                        AIUsageLog[]
  adminCompanyNotesAuthored          AdminCompanyNote[]       @relation("AdminCompanyNotesAuthored")
  adminUserNotesAuthored             AdminUserNote[]          @relation("AdminUserNotesAuthored")
  adminUserNotesAbout                AdminUserNote[]          @relation("AdminUserNotesAbout")
  adminSubscriptionNotesAuthored     AdminSubscriptionNote[]  @relation("AdminSubscriptionNotesAuthored")
  adminPaymentNotesAuthored          AdminPaymentNote[]       @relation("AdminPaymentNotesAuthored")
  adminPlanNotesAuthored             AdminPlanNote[]          @relation("AdminPlanNotesAuthored")
  adminPartnerNotesAuthored          AdminPartnerNote[]       @relation("AdminPartnerNotesAuthored")
  adminPartnerPayoutNotesAuthored    AdminPartnerPayoutNote[] @relation("AdminPartnerPayoutNotesAuthored")
  partnerPayoutsPaid                 PartnerPayout[]          @relation("PartnerPayoutsPaidBy")
  systemJobRunsTriggered             SystemJobRun[]           @relation("SystemJobRunsTriggeredBy")
  companyOnboardingUpdates           CompanyOnboarding[]      @relation("CompanyOnboardingUpdatedBy")
  platformSettingsUpdated            PlatformSettings[]       @relation("PlatformSettingsUpdatedBy")
  cancellationScheduledSubscriptions CompanySubscription[]    @relation("SubscriptionCancellationScheduledBy")
  passwordResetTokens                PasswordResetToken[]
  passwordResetsCreated              PasswordResetToken[]     @relation("PasswordResetCreatedByAdmin")
  mobileSessions                     MobileSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserConsent {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        UserConsentType
  version     String
  acceptedAt  DateTime        @default(now())
  ip          String?
  userAgent   String?
  consentText String?

  @@index([userId, type])
  @@index([acceptedAt])
}

model Company {
  id        String  @id @default(cuid())
  name      String
  taxNo     String?
  taxOffice String?
  phone     String?
  email     String?
  address   String?
  logoUrl   String?
  status    Status  @default(ACTIVE)

  users                          CompanyUser[]
  customers                      Customer[]
  customerGroups                 CustomerGroup[]
  products                       Product[]
  categories                     ProductCategory[]
  sales                          Sale[]
  salePayments                   SalePayment[]
  invoices                       Invoice[]
  expenses                       Expense[]
  expenseCategories              ExpenseCategory[]
  accounts                       Account[]
  stockMovements                 StockMovement[]
  membershipPayments             MembershipPayment[]
  paymentAttempts                PaymentAttempt[]
  paymentMethods                 CompanyPaymentMethod[]
  paymentRefunds                 PaymentRefund[]
  billingRuns                    SubscriptionBillingRun[]
  billingOutboxEvents            BillingOutboxEvent[]
  subscription                   CompanySubscription?
  notifications                  Notification[]
  activityLogs                   ActivityLog[]
  settings                       CompanySettings?
  invites                        CompanyInvite[]
  warehouses                     Warehouse[]
  warehouseStocks                WarehouseStock[]
  warehouseTransfers             WarehouseTransfer[]
  marketplaceIntegrations        MarketplaceIntegration[]
  marketplaceSyncRuns            MarketplaceSyncRun[]
  productChannelMappings         ProductChannelMapping[]
  efaturamIntegration            EfaturamIntegration?
  invoiceDocumentSubmissions     InvoiceDocumentSubmission[]
  eDocumentTaxpayerLookupCaches  EDocumentTaxpayerLookupCache[]
  eDocumentGibUserListCache      EDocumentGibUserListCache?
  calendarEvents                 CalendarEvent[]
  employees                      Employee[]
  employeeSalaries               EmployeeSalary[]
  employeePayments               EmployeePayment[]
  employeeLeaves                 EmployeeLeave[]
  employeePerformanceRecords     EmployeePerformanceRecord[]
  employeePerformanceTargets     EmployeePerformanceTarget[]
  payrollRuns                    PayrollRun[]
  payrollRunItems                PayrollRunItem[]
  employeeDepartments            EmployeeDepartment[]
  directoryContacts              DirectoryContact[]
  suppliers                      Supplier[]
  supplierLedgerEntries          SupplierLedgerEntry[]
  supplierContacts               SupplierContact[]
  supplierProducts               SupplierProduct[]
  partnerConversions             PartnerConversion[]
  campaignScopes                 MembershipCampaignScope[]
  couponRedemptions              MembershipCouponRedemption[]
  discountRedemptions            MembershipDiscountRedemption[]
  planPriceOverrides             CompanyPlanPriceOverride[]
  addOnSubscriptions             CompanyAddOnSubscription[]
  entitlementOverrides           CompanyEntitlementOverride[]
  usagePeriods                   UsagePeriod[]
  usageEvents                    UsageEvent[]
  usageCredits                   CompanyUsageCredit[]
  aiSettings                     CompanyAISettings?
  aiConversations                AIConversation[]
  aiUsageLogs                    AIUsageLog[]
  aiInsightCaches                AIInsightCache[]
  adminNotes                     AdminCompanyNote[]
  onboarding                     CompanyOnboarding?
  invoiceCollectionIdempotencies InvoiceCollectionIdempotency[]

  referringPartnerId String?
  referringPartner   PartnerProfile? @relation("ReferredCompanies", fields: [referringPartnerId], references: [id], onDelete: SetNull)
  referralCode       String?
  referredAt         DateTime?

  suspendedAt       DateTime?
  suspendedReason   String?
  suspendedUntil    DateTime?
  suspendedByUserId String?
  archivedAt        DateTime?
  archivedByUserId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CompanyOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

model CompanyOnboarding {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status      CompanyOnboardingStatus @default(NOT_STARTED)
  currentStep Int                     @default(1)
  flowVersion Int                     @default(1)

  checklistDismissedAt DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  dismissedAt          DateTime?

  updatedByUserId String?
  updatedByUser   User?   @relation("CompanyOnboardingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
}

enum SupplierLedgerEntryType {
  OPENING_BALANCE
  PAYMENT
  COLLECTION
  ADJUSTMENT
}

enum DirectoryContactType {
  PERSON
  COMPANY
  CUSTOMER
  EMPLOYEE
  SUPPLIER
  OTHER
}

enum DirectorySourceType {
  MANUAL
  CUSTOMER
  EMPLOYEE
  SUPPLIER
}

model DirectoryContact {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type       DirectoryContactType @default(PERSON)
  sourceType DirectorySourceType? @default(MANUAL)
  sourceId   String?

  name        String
  companyName String?
  title       String?
  department  String?
  phone       String?
  mobilePhone String?
  email       String?
  website     String?
  address     String?
  city        String?
  district    String?
  taxNumber   String?
  notes       String?
  tags        String[] @default([])
  isFavorite  Boolean  @default(false)
  isActive    Boolean  @default(true)

  createdByUserId String?
  createdByUser   User?   @relation("DirectoryContactCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sourceType, sourceId])
  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, isFavorite])
  @@index([companyId, isActive])
}

model CompanyInvite {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email           String
  role            UserRole
  token           String              @unique
  status          CompanyInviteStatus @default(PENDING)
  invitedByUserId String
  invitedBy       User                @relation("SentInvites", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, email, status])
  @@index([companyId])
}

model CompanySettings {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  currency       String @default("TRY")
  defaultVatRate Int    @default(20)

  defaultInvoiceType  InvoiceType @default(E_ARCHIVE)
  invoiceNumberPrefix String      @default("FTR")
  defaultDueDays      Int         @default(30)
  invoiceNoteTemplate String?

  defaultCollectionAccountId String?
  defaultExpenseAccountId    String?
  autoCreateCashAccount      Boolean @default(true)
  hideInactiveAccounts       Boolean @default(true)

  allowNegativeStockSales  Boolean @default(false)
  allowNegativeCashBalance Boolean @default(false)

  notifyLowStock         Boolean @default(true)
  notifyDueInvoices      Boolean @default(true)
  notifyLateCollections  Boolean @default(true)
  notifyDailySummary     Boolean @default(false)
  notifyEmployeePayments Boolean @default(true)

  membershipStatus MembershipStatus @default(ACTIVE)
  lastPaymentDate  DateTime?
  nextPaymentDate  DateTime?
  monthlyFee       Decimal          @default(1499)
  membershipNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyUser {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role    UserRole          @default(STAFF)
  status  CompanyUserStatus @default(ACTIVE)
  isOwner Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee?

  @@unique([companyId, userId])
}

model Customer {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                   String
  phone                  String?
  email                  String?
  taxNo                  String?
  taxOffice              String?
  taxCertificateUrl      String?
  taxCertificateFileName String?
  taxCertificateMimeType String?
  taxCertificateSize     Int?
  address                String?
  group                  String?
  balance                Decimal @default(0)
  status                 Status  @default(ACTIVE)

  linkedSuppliers Supplier[] @relation("SupplierLinkedCustomer")

  sales    Sale[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model CustomerGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  color     String?  @default("blue")
  note      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

model Supplier {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code               String?
  name               String
  companyName        String?
  contactName        String?
  phone              String?
  mobilePhone        String?
  email              String?
  website            String?
  taxOffice          String?
  taxNumber          String?
  iban               String?
  address            String?
  city               String?
  district           String?
  country            String    @default("Türkiye")
  category           String?
  tags               String[]  @default([])
  notes              String?
  openingBalance     Decimal   @default(0) @db.Decimal(12, 2)
  openingBalanceDate DateTime?
  openingBalanceNote String?
  currentBalance     Decimal   @default(0) @db.Decimal(12, 2)
  currency           String    @default("TRY")
  paymentTermDays    Int?
  isActive           Boolean   @default(true)
  isFavorite         Boolean   @default(false)

  linkedCustomerId String?
  linkedCustomer   Customer? @relation("SupplierLinkedCustomer", fields: [linkedCustomerId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdByUser   User?   @relation("SupplierCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  contacts            SupplierContact[]
  supplierProducts    SupplierProduct[]
  expenses            Expense[]
  stockMovements      StockMovement[]
  ledgerEntries       SupplierLedgerEntry[]
  accountTransactions AccountTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, isFavorite])
  @@index([companyId, name])
  @@index([companyId, taxNumber])
  @@index([companyId, linkedCustomerId])
}

model SupplierLedgerEntry {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  type          SupplierLedgerEntryType
  amount        Decimal                 @db.Decimal(12, 2)
  balanceEffect Decimal                 @db.Decimal(12, 2)
  date          DateTime
  description   String?
  reason        String?

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  accountTransactionId String?             @unique
  accountTransaction   AccountTransaction? @relation(fields: [accountTransactionId], references: [id], onDelete: SetNull)

  sourceType     String?
  sourceId       String?
  idempotencyKey String?

  createdByUserId String?
  createdByUser   User?   @relation("SupplierLedgerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([companyId, sourceType, sourceId])
  @@unique([companyId, idempotencyKey])
  @@index([companyId, supplierId])
  @@index([supplierId, date])
}

model SupplierContact {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  name      String
  title     String?
  phone     String?
  email     String?
  notes     String?
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([supplierId])
}

model SupplierProduct {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierSku      String?
  supplierBarcode  String?
  purchasePrice    Decimal? @db.Decimal(12, 2)
  currency         String   @default("TRY")
  minOrderQuantity Int?
  leadTimeDays     Int?
  isPreferred      Boolean  @default(false)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, supplierId, productId])
  @@index([companyId])
  @@index([supplierId])
  @@index([productId])
}

enum ProductUnitType {
  PIECE
  KG
  METER
  LITER
  PACK
  HOUR
  DAY
  JOB
}

enum ProductType {
  STOCK
  SERVICE
}

model ProductCategory {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  color     String?
  note      String?
  status    Status  @default(ACTIVE)
  sortOrder Int     @default(100)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  name              String
  sku               String?
  barcode           String?
  description       String?
  productType       ProductType     @default(STOCK)
  imageUrl          String?
  stock             Int             @default(0)
  minStock          Int             @default(10)
  unitType          ProductUnitType @default(PIECE)
  warehouseLocation String?
  buyPrice          Decimal         @default(0)
  sellPrice         Decimal         @default(0)
  vatRate           Int             @default(20)
  status            Status          @default(ACTIVE)

  saleItems          SaleItem[]
  invoiceItems       InvoiceItem[]
  stockMovements     StockMovement[]
  warehouseStocks    WarehouseStock[]
  warehouseTransfers WarehouseTransfer[]
  transferItems      WarehouseTransferItem[]
  channelMappings    ProductChannelMapping[]
  supplierProducts   SupplierProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
}

model Warehouse {
  id        String          @id @default(cuid())
  companyId String
  name      String
  code      String?
  address   String?
  note      String?
  isDefault Boolean         @default(false)
  status    WarehouseStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks                  WarehouseStock[]
  fromTransfers           WarehouseTransfer[]      @relation("WarehouseTransferFrom")
  toTransfers             WarehouseTransfer[]      @relation("WarehouseTransferTo")
  stockMovements          StockMovement[]
  sales                   Sale[]
  saleItems               SaleItem[]
  marketplaceIntegrations MarketplaceIntegration[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WarehouseStock {
  id          String   @id @default(cuid())
  companyId   String
  warehouseId String
  productId   String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([companyId])
  @@index([productId])
}

model WarehouseTransfer {
  id              String                  @id @default(cuid())
  companyId       String
  transferNo      String
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  quantity        Int
  note            String?
  status          WarehouseTransferStatus @default(PENDING)
  idempotencyKey  String?
  payloadHash     String?
  completedAt     DateTime?
  createdByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse  Warehouse               @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse               @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  product        Product                 @relation(fields: [productId], references: [id])
  createdBy      User?                   @relation(fields: [createdByUserId], references: [id])
  stockMovements StockMovement[]
  items          WarehouseTransferItem[]

  @@unique([companyId, transferNo])
  @@unique([companyId, idempotencyKey])
  @@index([companyId])
  @@index([productId])
}

model WarehouseTransferItem {
  id         String   @id @default(cuid())
  transferId String
  productId  String
  quantity   Int
  createdAt  DateTime @default(now())

  transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([productId])
}

model Sale {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String?
  user   User?   @relation("SaleCreatedBy", fields: [userId], references: [id])

  saleNo   String  @unique
  subtotal Decimal @default(0)
  vatTotal Decimal @default(0)
  discount Decimal @default(0)
  total    Decimal @default(0)

  /// POS checkout idempotency — company-scoped unique when set
  idempotencyKey String?
  payloadHash    String?

  status        SaleStatus    @default(COMPLETED)
  paymentStatus PaymentStatus @default(UNPAID)
  paidAmount    Decimal       @default(0)
  note          String?

  sourceChannel   OrderSourceChannel @default(MANUAL)
  externalOrderId String?
  orderStatus     OrderStatus        @default(WAITING)
  shippingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  orderNote       String?

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  saleDate DateTime @default(now())

  revisionNumber Int @default(0)

  cancelledAt       DateTime?
  cancelledByUserId String?
  cancelledByUser   User?     @relation("SaleCancelledBy", fields: [cancelledByUserId], references: [id])
  cancelReason      String?
  cancelNote        String?

  items    SaleItem[]
  payments SalePayment[]
  invoice  Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sourceChannel, externalOrderId])
  @@unique([companyId, idempotencyKey])
  @@index([companyId])
  @@index([warehouseId])
  @@index([companyId, orderStatus])
  @@index([companyId, sourceChannel])
  @@index([companyId, createdAt])
  @@index([companyId, saleDate])
}

model SaleItem {
  id String @id @default(cuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  name      String
  quantity  Int
  unitPrice Decimal
  vatRate   Int     @default(20)
  total     Decimal

  createdAt DateTime @default(now())
}

model SalePayment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  paymentMethod PosPaymentMethod
  amount        Decimal

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([saleId])
  @@index([accountId])
}

model MarketplaceIntegration {
  id                      String                       @id @default(cuid())
  companyId               String
  channel                 MarketplaceChannel
  status                  MarketplaceIntegrationStatus @default(DISCONNECTED)
  credentialsEncrypted    String?
  supplierId              String?
  merchantId              String?
  syncEnabled             Boolean                      @default(false)
  autoSyncIntervalMinutes Int                          @default(15)
  defaultWarehouseId      String?
  lastSyncAt              DateTime?
  lastSyncCursor          String?
  lastSyncStatus          String?
  lastError               String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultWarehouse Warehouse?           @relation(fields: [defaultWarehouseId], references: [id])
  syncRuns         MarketplaceSyncRun[]

  @@unique([companyId, channel])
  @@index([companyId])
}

model MarketplaceSyncRun {
  id            String                   @id @default(cuid())
  companyId     String
  integrationId String
  channel       MarketplaceChannel
  type          MarketplaceSyncRunType
  status        MarketplaceSyncRunStatus
  fetchedCount  Int                      @default(0)
  createdCount  Int                      @default(0)
  updatedCount  Int                      @default(0)
  skippedCount  Int                      @default(0)
  errors        Json?
  startedAt     DateTime                 @default(now())
  finishedAt    DateTime?
  createdAt     DateTime                 @default(now())

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([integrationId])
  @@index([channel])
}

model ProductChannelMapping {
  id                String             @id @default(cuid())
  companyId         String
  productId         String
  channel           MarketplaceChannel
  merchantSku       String
  barcode           String?
  externalProductId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel, merchantSku])
  @@index([companyId])
  @@index([productId])
}

/// Provider-agnostic e-document integration (legacy table name preserved).
