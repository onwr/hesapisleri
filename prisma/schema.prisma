  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([expiresAt])
}

/// Tenant + taxId bazlı kısa süreli mükellef sorgu cache.
model EDocumentTaxpayerLookupCache {
  id        String   @id @default(cuid())
  companyId String
  taxId     String
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, taxId])
  @@index([companyId])
  @@index([expiresAt])
}

model Invoice {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  saleId String? @unique
  sale   Sale?   @relation(fields: [saleId], references: [id])

  invoiceNo               String                  @unique
  type                    InvoiceType             @default(NORMAL)
  status                  InvoiceStatus           @default(DRAFT)
  subtotal                Decimal                 @default(0)
  totalDiscount           Decimal                 @default(0)
  taxableAmount           Decimal                 @default(0)
  totalVat                Decimal                 @default(0)
  total                   Decimal                 @default(0)
  financialSnapshotStatus FinancialSnapshotStatus @default(NEEDS_REVIEW)

  paymentStatus PaymentStatus @default(UNPAID)
  paidAmount    Decimal       @default(0)

  gibStatus  String?
  gibMessage String?
  pdfUrl     String?
  xmlUrl     String?

  sellerSnapshot          Json?
  buyerSnapshot           Json?
  lineSnapshots           Json?
  internetSaleSnapshot    Json?
  financialSnapshot       Json?
  eDocumentSnapshotAt     DateTime?
  eDocumentSnapshotStatus EDocumentSnapshotStatus?
  eDocumentRevisionHash   String?
  eDocumentSnapshotHash   String?

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items              InvoiceItem[]
  transactions       AccountTransaction[]
  documentSubmission InvoiceDocumentSubmission?

  @@index([companyId])
}

model InvoiceItem {
  id String @id @default(cuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  sourceSaleItemId String?

  productName String
  description String?
  sku         String?
  barcode     String?
  unit        String?

  quantity        Decimal
  unitPrice       Decimal
  discountRate    Decimal @default(0)
  discountAmount  Decimal @default(0)
  lineNetAmount   Decimal
  vatRate         Decimal
  vatAmount       Decimal
  lineGrossAmount Decimal
  lineIndex       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([productId])
}

model ExpenseCategory {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  color     String?               @default("blue")
  note      String?
  sortOrder Int                   @default(100)
  status    ExpenseCategoryStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Expense {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  title                 String
  category              String?
  supplier              String?
  supplierId            String?
  supplierRef           Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  amount                Decimal
  status                ExpenseStatus         @default(APPROVED)
  paymentStatus         ExpensePaymentStatus  @default(UNPAID)
  accountId             String?
  account               Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountTransaction    AccountTransaction?
  employeePayments      EmployeePayment[]     @relation("EmployeePaymentExpense")
  supplierLedgerEntries SupplierLedgerEntry[]
  date                  DateTime              @default(now())
  note                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([accountId])
  @@index([supplierId])
}

model Account {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type          AccountType
  name          String
  bankName      String?
  branchName    String?
  iban          String?
  accountNumber String?
  balance       Decimal     @default(0)
  currency      String      @default("TRY")
  isDefault     Boolean     @default(false)
  description   String?
  status        Status      @default(ACTIVE)

  transactions     AccountTransaction[]
  expenses         Expense[]
  employeePayments EmployeePayment[]    @relation("EmployeePaymentAccount")
  salePayments     SalePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AccountTransaction {
  id String @id @default(cuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type   TransactionType
  title  String
  amount Decimal
  date   DateTime        @default(now())
  note   String?

  expenseId String?  @unique
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  employeePayments    EmployeePayment[]    @relation("EmployeePaymentTransaction")
  supplierLedgerEntry SupplierLedgerEntry?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([supplierId])
}

model StockMovement {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  transferId String?
  transfer   WarehouseTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  type         StockMovementType
  quantity     Int
  note         String?
  movementDate DateTime          @default(now())

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([warehouseId])
  @@index([transferId])
  @@index([supplierId])
