  adminNote              String?
  createdByUserId        String?
  publishedByUserId      String?
  publishedAt            DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  lockedSubscriptions CompanySubscription[] @relation("SubscriptionLockedPrice")
  nextSubscriptions   CompanySubscription[] @relation("SubscriptionNextPrice")
  payments            MembershipPayment[]

